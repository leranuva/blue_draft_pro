# ============================================
# Blue Draft — Hostinger Production Template
# ============================================
# Copy to .env and fill with your values

APP_NAME="Blue Draft"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://bluedraft.cc
ASSET_URL=https://bluedraft.cc

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# Base de datos — Hostinger usa MySQL por defecto
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u123456789_blue_draft
DB_USERNAME=u123456789_user
DB_PASSWORD=tu_contraseña_segura

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Hostinger shared: usar sync (no hay worker para queue:work)
# Los jobs se ejecutan cuando cron corre schedule:run
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=info@bluedraft.cc
MAIL_PASSWORD=tu_contraseña_email
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@bluedraft.cc"
MAIL_FROM_NAME="${APP_NAME}"
ADMIN_NOTIFICATION_EMAIL=info@bluedraft.cc

# reCAPTCHA (recomendado en producción)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Secuencia de emails (6 correos automáticos)
EMAIL_SEQUENCE_ENABLED=true
BREVO_API_KEY=
BREVO_LIST_ID=

# Tracking
GTM_ID=
GA4_MEASUREMENT_ID=
META_PIXEL_ID=

VITE_APP_NAME="${APP_NAME}"
